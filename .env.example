# ---------------------------------------------------------------------------
# SuperZ / Prompt Compressor — environment configuration
# Copy this file to .env and fill in the keys you have.
# Providers with no key are silently skipped; you need at least one.
# ---------------------------------------------------------------------------

# Fast tier (free-first default)
# OpenRouter free model is the primary provider out of the box.
OPENROUTER_API_KEY=

# Optional fallbacks (paid or owned-provider keys for reliability)
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
HF_API_KEY=

# Optional model overrides (defaults in src/config/load.ts)
# CEREBRAS_MODEL=llama-3.3-70b
# GROQ_MODEL=llama-3.1-8b-instant
# GOOGLE_MODEL=gemini-2.0-flash
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# HF_MODEL=meta-llama/llama-3.1-8b-instruct

# Logger verbosity: silent | error | warn | info | debug | trace
SUPERZ_LOG=info

# HTTP mode: bearer token required when running `superz serve --http`
SUPERZ_HTTP_TOKEN=
